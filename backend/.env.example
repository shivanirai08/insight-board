# Application
APP_NAME=InsightBoard
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# Server
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Security (change in production)
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg://insight:insight@localhost:5432/insightboard

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL (post-login redirect)
FRONTEND_URL=http://localhost:5173

# Local-only login without Google (set false in production)
ENABLE_DEV_LOGIN=true

# Optional override; default is <repo>/sample_data/sales_sample.csv
# SAMPLE_DATA_PATH=/absolute/path/to/sales_sample.csv
